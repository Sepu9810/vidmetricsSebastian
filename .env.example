# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Convex Site URL (for auth callback redirects)
NEXT_PUBLIC_CONVEX_SITE_URL=

# Convex Deploy Key (for preview/production deployments)
CONVEX_DEPLOY_KEY=

# Public app URL used in emails generated by Convex actions
NEXT_PUBLIC_APP_URL=

# The variables below run inside Convex actions/functions.
# Set them in the Convex dashboard environment, not in Vercel.
# APIFY_API_TOKEN=
# OPENAI_API_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
